#!/bin/bash

# Only run on Darwin (macOS)
{{ if eq .chezmoi.os "darwin" -}}

set -euo pipefail

# Ensure Homebrew can be found even when PATH is minimal.
if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
fi

if ! command -v brew >/dev/null 2>&1; then
    echo "Homebrew is not available; skipping package installation."
    exit 0
fi

if [[ -f "$HOME/.Brewfile" ]]; then
    # Homebrew may require explicit trust for third-party taps on fresh machines.
    if brew help trust >/dev/null 2>&1; then
        while IFS= read -r tap; do
            [[ -z "$tap" ]] && continue
            echo "Trusting Homebrew tap: $tap"
            brew trust "$tap" || echo "Warning: failed to trust tap $tap"
        done < <(sed -n 's/^tap "\([^"]*\)".*/\1/p' "$HOME/.Brewfile")
    fi

    echo "Installing Homebrew packages from $HOME/.Brewfile ..."
    if ! brew bundle install --file="$HOME/.Brewfile"; then
        echo "Warning: brew bundle failed, likely due to one or more casks requiring extra permissions."
        cask_skip_list=$(sed -n 's/^cask "\([^"]*\)".*/\1/p' "$HOME/.Brewfile" | tr '\n' ' ' | sed 's/[[:space:]]*$//')

        if [[ -n "$cask_skip_list" ]]; then
            echo "Retrying without casks to avoid blocking chezmoi apply..."
            HOMEBREW_BUNDLE_CASK_SKIP="$cask_skip_list" brew bundle install --file="$HOME/.Brewfile"
            echo "Non-cask packages installed. Please install casks manually if needed."
            echo "Example: brew install --cask docker-desktop"
        else
            echo "No casks found in Brewfile; keeping original failure."
            exit 1
        fi
    fi
else
    echo "No Brewfile found at $HOME/.Brewfile; skipping package installation."
fi

{{ end -}}
